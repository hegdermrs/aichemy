# ============================================================================
# Local development (matches docker-compose.yml)
# ============================================================================

# --- Database ---
# Local: docker Postgres on host port 5433.
# Production (Railway): copy the Postgres plugin's connection string. Append
# `?sslmode=require` if your provider needs TLS (Neon/Supabase do).
DATABASE_URL="postgresql://craft:craft@localhost:5433/infinite_craft?schema=public"

# --- Redis (OPTIONAL) ---
# Local: docker Redis on host port 6380.
# Production (Railway): the Redis plugin's URL. If unset/unreachable the app
# still works — it just skips the Redis cache tier and falls through to Postgres.
REDIS_URL="redis://localhost:6380"

# --- DeepSeek (OpenAI-compatible API) ---
# Get a key at https://platform.deepseek.com/api_keys
# If left empty, the app falls back to a deterministic mock generator so it still runs.
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"
